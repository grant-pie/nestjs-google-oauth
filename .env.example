# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=auth

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=1d
